{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "paolobellini/laravel-preset",
    "description": "Opinionated Laravel preset: dev tooling, code conventions and AI agent guidelines scaffolded into new projects.",
    "keywords": [
        "laravel",
        "preset",
        "scaffolding",
        "conventions",
        "pint",
        "rector",
        "pest"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Paolo Bellini",
            "email": "paolo@bellini.one"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/console": "^11.0 || ^12.0 || ^13.0",
        "illuminate/filesystem": "^11.0 || ^12.0 || ^13.0",
        "illuminate/process": "^11.0 || ^12.0 || ^13.0",
        "illuminate/support": "^11.0 || ^12.0 || ^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0 || ^10.0",
        "laravel/pint": "^1.27",
        "pestphp/pest": "^3.0 || ^4.0"
    },
    "autoload": {
        "psr-4": {
            "PaoloBellini\\LaravelPreset\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PaoloBellini\\LaravelPreset\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "PaoloBellini\\LaravelPreset\\PresetServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
